      "Skill(commit)",
      "Skill(pr)",
      "Skill(rebase)",
      "Skill(interview)",
      "WebFetch",
      "WebSearch",
      "Bash(awk:*)",
      "Bash(cat:*)",
      "Bash(curl:*)",
      "Bash(diff:*)",
      "Bash(du:*)",
      "Bash(fd:*)",
      "Bash(file:*)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(sed:*)",
      "Bash(stat:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git describe:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git for-each-ref:*)",
      "Bash(git filter-branch:*)",
      "Bash(git log:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(git tag -l:*)",
      "Bash(git tag --sort:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue status:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr status:*)",
      "Bash(gh pr view:*)",
      "Bash(gh search:*)",
      "Bash(glab issue list:*)",
      "Bash(glab issue view:*)",
      "Bash(glab mr list:*)",
      "Bash(glab mr view:*)",
      "Bash(npm info:*)",
      "Bash(npm search:*)",
      "Bash(pnpm info:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm remove:*)",
      "Bash(pnpm run build:*)",
      "Bash(pnpm run lint:*)",
      "Bash(pnpm run test:*)",
      "Bash(pnpm run dev:*)",
      "Bash(pnpm search:*)",
      "Bash(node --check:*)",
      "Bash(uv:*)",
      "Bash(uv venv:*)",
      "Bash(uv pip:*)",
      "Bash(uv sync:*)",
      "Bash(uv add:*)",
      "Bash(uv remove:*)",
      "Bash(uv run:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(lsof -ti:8000)",
      "Bash(open http://localhost:3000)",
      "Bash(pkill -f \"uvicorn.*weaver\")",
      "Bash(kill 66067 66079 66080)",
      "Bash(pip show:*)",
      "Bash(curl -s -X POST http://localhost:8000/api/v1/runs/test -H \"Content-Type: application/json\" -d '{\"\"\"\"test\"\"\"\": \"\"\"\"data\"\"\"\"}')",
      "Bash(.venv/bin/python -c \"import multipart; print\\(''python-multipart is installed''\\)\")",
      "Bash(pkill -9 -f \"uvicorn.*app.main\")",
      "Bash(xargs kill:*)",
      "Bash(kill -9 24415 24428)",
      "Bash(.venv/bin/uvicorn app.main:app --reload --port 8000)",
      "Bash(.venv/bin/python test_api.py)",
      "Bash(.venv/bin/python -c \"import fastapi; import pydantic; print\\(f''FastAPI: {fastapi.__version__}''\\); print\\(f''Pydantic: {pydantic.__version__}''\\)\")",
      "Bash(git init:*)",
      "Bash(chmod +x /Users/sadhasivam/Jawn/Code/texture/Weaver/scripts/download_boston_housing.sh)",
      "Bash(./scripts/download_boston_housing.sh)"
    ],
    "deny": [
      "Read(.env*)",
      "Read(**/.env*)",
      "Read(**/secrets/**)",
      "Read(**/credentials.*)"
    ],
    "ask": [
      "Read(~/.config/*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-npm.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/block-pip.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  }
}
