      "Bash(gh issue status:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr status:*)",
      "Bash(gh pr view:*)",
      "Bash(gh search:*)",
      "Bash(npm info:*)",
      "Bash(npm search:*)",
      "Bash(pnpm info:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm remove:*)",
      "Bash(pnpm run build:*)",
      "Bash(pnpm run lint:*)",
      "Bash(pnpm run test:*)",
      "Bash(pnpm run dev:*)",
      "Bash(pnpm search:*)",
      "Bash(node --check:*)",
      "Bash(uv:*)",
      "Bash(uv venv:*)",
      "Bash(uv pip:*)",
      "Bash(uv sync:*)",
      "Bash(uv add:*)",
      "Bash(uv remove:*)",
      "Bash(uv run:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(lsof -ti:8000)",
      "Bash(git init:*)",
      "Bash(pnpm vercel:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm preview:*)",
      "Bash(git push:*)",
      "Bash(git revert:*)",
      "Bash(make start:*)",
      "Bash(make status:*)",
      "Bash(make stop:*)",
      "Bash(caddy stop:*)",
      "Bash(caddy start:*)",
      "Bash(make build:*)",
      "Bash(.venv/bin/pip install:*)",
      "Bash(xargs -n1 basename)",
      "Bash(for file:*)",
      "Bash(do)",
      "Bash(done)"
    ],
    "deny": [
      "Read(.env*)",
      "Read(**/.env*)",
      "Read(**/secrets/**)",
      "Read(**/credentials.*)"
    ],
    "ask": [
      "Read(~/.config/*)"
    ],
    "additionalDirectories": [
      "/Users/sadhasivam/Jawn/Code/texture/Weaver/app/storage/uploads",
      "/Users/sadhasivam/Jawn/Code/texture/.github"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-npm.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/block-pip.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "kotlin-lsp@claude-plugins-official": true,
    "data-engineering@claude-plugins-official": true
  }
}
