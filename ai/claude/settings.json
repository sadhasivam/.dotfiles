      "Skill(rebase)",
      "Skill(interview)",
      "WebFetch",
      "WebSearch",
      "Bash(awk:*)",
      "Bash(cat:*)",
      "Bash(curl:*)",
      "Bash(diff:*)",
      "Bash(du:*)",
      "Bash(fd:*)",
      "Bash(file:*)",
